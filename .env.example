# このファイルを .env にコピーして、値を入れてください。
SLACK_WEBHOOK_URL_A=https://hooks.slack.com/services/XXXXX/XXXXX/XXXXXXXXX
SLACK_WEBHOOK_URL_B=https://hooks.slack.com/services/XXXXX/XXXXX/XXXXXXXXX
# 任意（未設定の Webhook のときの共通先）
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXXXX/XXXXX/XXXXXXXXX
# PR TIMES の RSS（カンマ区切りで複数可）
# PRTIMES_RSS_URLS=https://prtimes.jp/index.rdf
# ログをファイルに出すとき
# LOG_FILE=/path/to/cron.log
