# 必要に応じて値を入れて .env としてコピーしてください
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXXXX/XXXXX/XXXXXXXXX
# カンマ区切りで RSS URL を指定（デフォルトは https://prtimes.jp/index.rdf）
PRTIMES_RSS_URLS=https://prtimes.jp/index.rdf
# Channel B（一般IT）用 PR TIMES。未指定なら index.rdf
# GENERAL_TECH_PRTIMES_RSS_URLS=https://prtimes.jp/index.rdf
# Google News を B で併用する場合のみ（カンマ区切りクエリ）
# GENERAL_TECH_GOOGLE_NEWS_QUERIES=AIエージェント,脆弱性 CVE
# 追加RSS（Publickey 等）
# GENERAL_TECH_RSS_URLS=https://www.publickey1.jp/atom.xml
# ログファイルを残したい場合は指定（未指定なら標準出力のみ）
# LOG_FILE=/var/log/prtimes_med_it.log
